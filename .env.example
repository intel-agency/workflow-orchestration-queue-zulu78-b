# Environment Variables Template
# Copy this file to .env and fill in your values

# ===========================================
# Required Environment Variables
# ===========================================

# GitHub App Installation Token
# Generate from GitHub App settings or use GitHub CLI
GITHUB_TOKEN=your_github_token_here

# Target GitHub Organization
GITHUB_ORG=your_org_name

# Target GitHub Repository
GITHUB_REPO=your_repo_name

# Webhook Secret for HMAC signature verification
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================
# Optional Environment Variables
# ===========================================

# Sentinel Bot Login for assign-then-verify locking
# Set to the GitHub username of your bot account
SENTINEL_BOT_LOGIN=

# ZhipuAI API Key for LLM access
ZHIPU_API_KEY=

# Kimi API Key (alternative LLM)
KIMI_CODE_ORCHESTRATOR_AGENT_API_KEY=

# ===========================================
# Development Settings
# ===========================================

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Poll interval in seconds (default: 60)
POLL_INTERVAL=60
